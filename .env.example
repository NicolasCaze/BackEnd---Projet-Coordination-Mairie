# Configuration JWT
# Clé secrète pour la génération et validation des tokens JWT
# IMPORTANT: Générer une clé forte et unique pour chaque environnement
JWT_SECRET=your_jwt_secret_key_here_min_256_bits

# Durée de validité du token JWT en secondes (par défaut: 86400 = 24h)
JWT_EXPIRATION=86400

# Durée de validité du refresh token en secondes (par défaut: 604800 = 7 jours)
JWT_REFRESH_EXPIRATION=604800

# Configuration Base de données PostgreSQL
# URL de connexion à la base de données
DATABASE_URL=jdbc:postgresql://localhost:5432/mairie_db

# Nom d'utilisateur PostgreSQL
DATABASE_USERNAME=postgres

# Mot de passe PostgreSQL
DATABASE_PASSWORD=postgres

# Stratégie de gestion du schéma JPA (create, create-drop, update, validate, none)
JPA_DDL_AUTO=update

# Afficher les requêtes SQL dans les logs (true/false)
JPA_SHOW_SQL=false

# Configuration Upload de fichiers
# Répertoire de stockage des fichiers uploadés
UPLOAD_DIRECTORY=temp-uploads

# Taille maximale des fichiers en octets (par défaut: 10485760 = 10MB)
UPLOAD_MAX_SIZE=10485760

# Configuration SMTP pour l'envoi d'emails
# Serveur SMTP (ex: smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com

# Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_PORT=587

# Nom d'utilisateur SMTP (généralement l'adresse email)
SMTP_USERNAME=your_email@example.com

# Mot de passe SMTP ou mot de passe d'application
SMTP_PASSWORD=your_smtp_password

# Activer l'authentification SMTP (true/false)
SMTP_AUTH=true

# Activer STARTTLS (true/false)
SMTP_STARTTLS=true

# Adresse email du secrétariat pour les notifications
MAIL_SECRETARIAT=secretariat@mairie.fr
